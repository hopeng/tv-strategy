//@version=6
// -----------------------------------------------------------------------------
// Stochastic RSI Divergence v3 (K-first)
//
// Logic:
// 1) Detect K pivots first (using lbL/lbR).
// 2) Pair consecutive K pivots: ks (previous), ke (current).
// 3) Keep pair only if K forms divergence shape:
//    - Bear: ke <= ks (lower/equal high)
//    - Bull: ke >= ks (higher/equal low)
// 4) Map each K pivot to nearby price point in +/-3 bars:
//    - Prefer price pivots in that band
//    - If none, fallback to nearest local extreme in that band
// 5) Confirm divergence only when price condition also matches:
//    - Bear: pe > ps (higher high)
//    - Bull: pe < ps (lower low)
// -----------------------------------------------------------------------------
indicator(title="Stoch RSI Divergence v3", shorttitle="StochDivV3", overlay=false, max_lines_count=500, max_labels_count=500, max_bars_back=5000)

// --- Stoch RSI Inputs ---
smoothK     = input.int(3, "K Smoothing", minval=1)
smoothD     = input.int(3, "D Smoothing", minval=1)
lengthRSI   = input.int(14, "RSI Length", minval=1)
lengthStoch = input.int(14, "Stochastic Length", minval=1)
src         = input(close, title="RSI Source")

// --- Divergence Inputs ---
showDiv        = input.bool(true, "Show Divergence Lines")
lbR            = input.int(2, "Pivot Right Lookback", minval=1)
lbL            = input.int(2, "Pivot Left Lookback", minval=1)
priceColorBull = input.color(color.new(#FFFF00, 0), "Bullish price line color")
priceColorBear = input.color(color.new(#FF69B4, 0), "Bearish price line color")
priceMapRadius = input.int(5, "Price map radius (+/- bars)", minval=1, maxval=10)
requireNearbyPricePivot = input.bool(true, "Require nearby price pivot for ks/ke mapping")
maxKPenetration = input.float(2.0, "Max K penetration (avg pts)", minval=0.0, step=0.5)
maxPricePenetration = input.float(0.3, "Max price penetration (avg ATR ratio)", minval=0.0, step=0.1)
debugAllKPivots = input.bool(true, "Debug: plot all K pivots (high + low)")

// --- Calculations ---
rsi1 = ta.rsi(src, lengthRSI)
k = ta.sma(ta.stoch(rsi1, rsi1, rsi1, lengthStoch), smoothK)
d = ta.sma(k, smoothD)
atr14 = ta.atr(14)
max_bars_back(k, 5000)
max_bars_back(d, 5000)

// --- Plotting Stoch RSI ---
plot(k, "K", color=#2962FF, linewidth=2)
plot(d, "D", color=#FF6D00, linewidth=1)
h0 = hline(80, "Upper Band", color=#787B86, linestyle=hline.style_dashed)
hline(50, "Middle Band", color=color.new(#787B86, 50))
h1 = hline(20, "Lower Band", color=#787B86, linestyle=hline.style_dashed)
fill(h0, h1, color=color.rgb(33, 150, 243, 93), title="Background")

// Debug all %K pivots (confirmed with lbL/lbR; plotted on pivot bar via offset).
kPivotHighDbg = ta.pivothigh(k, lbL, lbR)
kPivotLowDbg = ta.pivotlow(k, lbL, lbR)
plotshape(debugAllKPivots ? kPivotHighDbg : na, title="All K pivot highs", style=shape.triangleup, location=location.absolute, offset=-lbR, color=color.new(color.yellow, 0), size=size.tiny)
plotshape(debugAllKPivots ? kPivotLowDbg : na, title="All K pivot lows", style=shape.triangledown, location=location.absolute, offset=-lbR, color=color.new(color.red, 0), size=size.tiny)

is_k_pivot_high(int b, int left, int right) =>
    int off = bar_index - b
    if off < 0 or na(k[off])
        false
    else
        float v = k[off]
        bool ok = true
        for i = 1 to left
            if off + i > bar_index or na(k[off + i]) or k[off + i] > v
                ok := false
                break
        if ok
            for i = 1 to right
                if off - i < 0 or na(k[off - i]) or k[off - i] > v
                    ok := false
                    break
        ok

is_k_pivot_low(int b, int left, int right) =>
    int off = bar_index - b
    if off < 0 or na(k[off])
        false
    else
        float v = k[off]
        bool ok = true
        for i = 1 to left
            if off + i > bar_index or na(k[off + i]) or k[off + i] < v
                ok := false
                break
        if ok
            for i = 1 to right
                if off - i < 0 or na(k[off - i]) or k[off - i] < v
                    ok := false
                    break
        ok

is_price_pivot_high(int b, int left, int right) =>
    int off = bar_index - b
    if off < 0 or na(high[off])
        false
    else
        float v = high[off]
        bool ok = true
        for i = 1 to left
            if off + i > bar_index or na(high[off + i]) or high[off + i] > v
                ok := false
                break
        if ok
            for i = 1 to right
                if off - i < 0 or na(high[off - i]) or high[off - i] > v
                    ok := false
                    break
        ok

is_price_pivot_low(int b, int left, int right) =>
    int off = bar_index - b
    if off < 0 or na(low[off])
        false
    else
        float v = low[off]
        bool ok = true
        for i = 1 to left
            if off + i > bar_index or na(low[off + i]) or low[off + i] < v
                ok := false
                break
        if ok
            for i = 1 to right
                if off - i < 0 or na(low[off - i]) or low[off - i] < v
                    ok := false
                    break
        ok

map_price_high_near(int kBar, int rad) =>
    int lo = math.max(0, kBar - rad)
    int hi = math.min(bar_index, kBar + rad)
    int bestB = na
    float bestP = na
    int bestDist = 2147483647
    for b = lo to hi
        if is_price_pivot_high(b, lbL, lbR)
            int dist = math.abs(b - kBar)
            if na(bestB) or dist < bestDist
                bestDist := dist
                bestB := b
                bestP := high[bar_index - b]
    if na(bestB) and not requireNearbyPricePivot
        // Fallback: nearest bar with max high in +/-rad
        float maxP = na
        for b = lo to hi
            float p = high[bar_index - b]
            if na(maxP) or p > maxP
                maxP := p
        bestDist := 2147483647
        for b = lo to hi
            float p = high[bar_index - b]
            if math.abs(p - maxP) < 0.0000001
                int dist = math.abs(b - kBar)
                if na(bestB) or dist < bestDist
                    bestDist := dist
                    bestB := b
                    bestP := p
    [bestP, bestB]

map_price_low_near(int kBar, int rad) =>
    int lo = math.max(0, kBar - rad)
    int hi = math.min(bar_index, kBar + rad)
    int bestB = na
    float bestP = na
    int bestDist = 2147483647
    for b = lo to hi
        if is_price_pivot_low(b, lbL, lbR)
            int dist = math.abs(b - kBar)
            if na(bestB) or dist < bestDist
                bestDist := dist
                bestB := b
                bestP := low[bar_index - b]
    if na(bestB) and not requireNearbyPricePivot
        // Fallback: nearest bar with min low in +/-rad
        float minP = na
        for b = lo to hi
            float p = low[bar_index - b]
            if na(minP) or p < minP
                minP := p
        bestDist := 2147483647
        for b = lo to hi
            float p = low[bar_index - b]
            if math.abs(p - minP) < 0.0000001
                int dist = math.abs(b - kBar)
                if na(bestB) or dist < bestDist
                    bestDist := dist
                    bestB := b
                    bestP := p
    [bestP, bestB]

avg_k_penetration(int startBar, float startVal, int endBar, float endVal, bool checkAbove) =>
    int span = endBar - startBar
    if span <= 1
        0.0
    else
        float slope = (endVal - startVal) / span
        float total = 0.0
        for i = 1 to span - 1
            int off = bar_index - (startBar + i)
            if off >= 0 and off <= 5000
                float lineVal = startVal + slope * i
                float kVal = k[off]
                if checkAbove
                    total += math.max(0.0, kVal - lineVal)
                else
                    total += math.max(0.0, lineVal - kVal)
        total / span

avg_price_pen_high(int startBar, float startPrice, int endBar, float endPrice) =>
    int span = endBar - startBar
    if span <= 1
        0.0
    else
        float slope = (endPrice - startPrice) / span
        float total = 0.0
        for i = 1 to span - 1
            int off = bar_index - (startBar + i)
            if off >= 0 and off <= 5000
                float lineVal = startPrice + slope * i
                total += math.max(0.0, high[off] - lineVal)
        total / span

avg_price_pen_low(int startBar, float startPrice, int endBar, float endPrice) =>
    int span = endBar - startBar
    if span <= 1
        0.0
    else
        float slope = (endPrice - startPrice) / span
        float total = 0.0
        for i = 1 to span - 1
            int off = bar_index - (startBar + i)
            if off >= 0 and off <= 5000
                float lineVal = startPrice + slope * i
                total += math.max(0.0, lineVal - low[off])
        total / span

// --- K-first state ---
var int   lastKHighBar = na
var float lastKHighVal = na
var int   prevKHighBar = na
var float prevKHighVal = na
var line  activeBearKLine = na
var line  activeBearPLine = na
var int   activeBearKsBar = na

var int   lastKLowBar = na
var float lastKLowVal = na
var int   prevKLowBar = na
var float prevKLowVal = na
var line  activeBullKLine = na
var line  activeBullPLine = na
var int   activeBullKsBar = na

// K pivot events (confirmed on this bar, pivot is at bar_index - lbR)
kPh = ta.pivothigh(k, lbL, lbR)
kPl = ta.pivotlow(k, lbL, lbR)

int _keBarH = bar_index - lbR
float _keValH = nz(kPh)
float bearConsPen = avg_k_penetration(nz(lastKHighBar, _keBarH), nz(lastKHighVal, _keValH), _keBarH, _keValH, true)
float bearLbPen = avg_k_penetration(nz(prevKHighBar, _keBarH), nz(prevKHighVal, _keValH), _keBarH, _keValH, true)

int _keBarL = bar_index - lbR
float _keValL = nz(kPl)
float bullConsPen = avg_k_penetration(nz(lastKLowBar, _keBarL), nz(lastKLowVal, _keValL), _keBarL, _keValL, false)
float bullLbPen = avg_k_penetration(nz(prevKLowBar, _keBarL), nz(prevKLowVal, _keValL), _keBarL, _keValL, false)

if showDiv and not na(kPh)
    int keBar = bar_index - lbR
    float keVal = kPh

    float consPen = bearConsPen
    float lbPen = bearLbPen

    bool consOk = false
    int  consKsBar = na
    float consKsVal = na
    int  consPsBar = na
    float consPsPrice = na
    int  consPeBar = na
    float consPePrice = na

    bool lbOk = false
    int  lbKsBar = na
    float lbKsVal = na
    int  lbPsBar = na
    float lbPsPrice = na
    int  lbPeBar = na
    float lbPePrice = na

    if not na(lastKHighBar) and not na(lastKHighVal) and keBar > lastKHighBar and keVal <= lastKHighVal
        consKsBar := lastKHighBar
        consKsVal := lastKHighVal
        [_psP, _psB] = map_price_high_near(consKsBar, priceMapRadius)
        [_peP, _peB] = map_price_high_near(keBar, priceMapRadius)
        consPsBar := _psB
        consPsPrice := _psP
        consPeBar := _peB
        consPePrice := _peP
        consOk := not na(_psB) and not na(_peB) and _peP > _psP
        if consOk and maxKPenetration > 0
            consOk := consPen <= maxKPenetration
        float _pPen = avg_price_pen_high(nz(_psB, keBar), nz(_psP, 0.0), nz(_peB, keBar), nz(_peP, 0.0))
        if consOk and maxPricePenetration > 0 and _pPen / atr14 > maxPricePenetration
            consOk := false

    if not na(prevKHighBar) and not na(prevKHighVal) and keBar > prevKHighBar and keVal <= prevKHighVal
        lbKsBar := prevKHighBar
        lbKsVal := prevKHighVal
        [_psP2, _psB2] = map_price_high_near(lbKsBar, priceMapRadius)
        [_peP2, _peB2] = map_price_high_near(keBar, priceMapRadius)
        lbPsBar := _psB2
        lbPsPrice := _psP2
        lbPeBar := _peB2
        lbPePrice := _peP2
        lbOk := not na(_psB2) and not na(_peB2) and _peP2 > _psP2
        if lbOk and maxKPenetration > 0
            lbOk := lbPen <= maxKPenetration
        float _pPen2 = avg_price_pen_high(nz(_psB2, keBar), nz(_psP2, 0.0), nz(_peB2, keBar), nz(_peP2, 0.0))
        if lbOk and maxPricePenetration > 0 and _pPen2 / atr14 > maxPricePenetration
            lbOk := false

    if lbOk
        if activeBearKsBar == lbKsBar
            if not na(activeBearKLine)
                line.set_style(activeBearKLine, line.style_dashed)
            if not na(activeBearPLine)
                line.set_style(activeBearPLine, line.style_dashed)
        activeBearKLine := line.new(lbKsBar, lbKsVal, keBar, keVal, color=color.red, width=2)
        activeBearPLine := line.new(lbPsBar, lbPsPrice, lbPeBar, lbPePrice, color=priceColorBear, width=2, force_overlay=true)
        activeBearKsBar := lbKsBar
        if debugAllKPivots
            if not na(lbPsBar)
                label.new(lbPsBar, lbPsPrice, "▲", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_none, color=color.new(color.blue, 100), textcolor=color.new(color.blue, 0), size=size.normal, force_overlay=true)
            if not na(lbPeBar)
                label.new(lbPeBar, lbPePrice, "▲", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_none, color=color.new(color.blue, 100), textcolor=color.new(color.blue, 0), size=size.normal, force_overlay=true)
    else if consOk
        activeBearKLine := line.new(consKsBar, consKsVal, keBar, keVal, color=color.red, width=2)
        activeBearPLine := line.new(consPsBar, consPsPrice, consPeBar, consPePrice, color=priceColorBear, width=2, force_overlay=true)
        activeBearKsBar := consKsBar
        if debugAllKPivots
            if not na(consPsBar)
                label.new(consPsBar, consPsPrice, "▲", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_none, color=color.new(color.blue, 100), textcolor=color.new(color.blue, 0), size=size.normal, force_overlay=true)
            if not na(consPeBar)
                label.new(consPeBar, consPePrice, "▲", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_none, color=color.new(color.blue, 100), textcolor=color.new(color.blue, 0), size=size.normal, force_overlay=true)

    if keVal > lastKHighVal
        prevKHighBar := na
        prevKHighVal := na
        activeBearKLine := na
        activeBearPLine := na
        activeBearKsBar := na
    else if not lbOk
        prevKHighBar := lastKHighBar
        prevKHighVal := lastKHighVal
    lastKHighBar := keBar
    lastKHighVal := keVal

if showDiv and not na(kPl)
    int keBar = bar_index - lbR
    float keVal = kPl

    float consPen = bullConsPen
    float lbPen = bullLbPen

    bool consOk = false
    int  consKsBar = na
    float consKsVal = na
    int  consPsBar = na
    float consPsPrice = na
    int  consPeBar = na
    float consPePrice = na

    bool lbOk = false
    int  lbKsBar = na
    float lbKsVal = na
    int  lbPsBar = na
    float lbPsPrice = na
    int  lbPeBar = na
    float lbPePrice = na

    if not na(lastKLowBar) and not na(lastKLowVal) and keBar > lastKLowBar and keVal >= lastKLowVal
        consKsBar := lastKLowBar
        consKsVal := lastKLowVal
        [_psP, _psB] = map_price_low_near(consKsBar, priceMapRadius)
        [_peP, _peB] = map_price_low_near(keBar, priceMapRadius)
        consPsBar := _psB
        consPsPrice := _psP
        consPeBar := _peB
        consPePrice := _peP
        consOk := not na(_psB) and not na(_peB) and _peP < _psP
        if consOk and maxKPenetration > 0
            consOk := consPen <= maxKPenetration
        float _pPen = avg_price_pen_low(nz(_psB, keBar), nz(_psP, 0.0), nz(_peB, keBar), nz(_peP, 0.0))
        if consOk and maxPricePenetration > 0 and _pPen / atr14 > maxPricePenetration
            consOk := false

    if not na(prevKLowBar) and not na(prevKLowVal) and keBar > prevKLowBar and keVal >= prevKLowVal
        lbKsBar := prevKLowBar
        lbKsVal := prevKLowVal
        [_psP2, _psB2] = map_price_low_near(lbKsBar, priceMapRadius)
        [_peP2, _peB2] = map_price_low_near(keBar, priceMapRadius)
        lbPsBar := _psB2
        lbPsPrice := _psP2
        lbPeBar := _peB2
        lbPePrice := _peP2
        lbOk := not na(_psB2) and not na(_peB2) and _peP2 < _psP2
        if lbOk and maxKPenetration > 0
            lbOk := lbPen <= maxKPenetration
        float _pPen2 = avg_price_pen_low(nz(_psB2, keBar), nz(_psP2, 0.0), nz(_peB2, keBar), nz(_peP2, 0.0))
        if lbOk and maxPricePenetration > 0 and _pPen2 / atr14 > maxPricePenetration
            lbOk := false

    float lowMarkerGap = math.max(syminfo.mintick * 12.0, atr14 * 0.15)

    if lbOk
        if activeBullKsBar == lbKsBar
            if not na(activeBullKLine)
                line.set_style(activeBullKLine, line.style_dashed)
            if not na(activeBullPLine)
                line.set_style(activeBullPLine, line.style_dashed)
        activeBullKLine := line.new(lbKsBar, lbKsVal, keBar, keVal, color=color.green, width=2)
        activeBullPLine := line.new(lbPsBar, lbPsPrice, lbPeBar, lbPePrice, color=priceColorBull, width=2, force_overlay=true)
        activeBullKsBar := lbKsBar
        if debugAllKPivots
            if not na(lbPsBar)
                label.new(lbPsBar, lbPsPrice - lowMarkerGap, "▼", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_none, color=color.new(#800080, 100), textcolor=color.new(#800080, 0), size=size.normal, force_overlay=true)
            if not na(lbPeBar)
                label.new(lbPeBar, lbPePrice - lowMarkerGap, "▼", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_none, color=color.new(#800080, 100), textcolor=color.new(#800080, 0), size=size.normal, force_overlay=true)
    else if consOk
        activeBullKLine := line.new(consKsBar, consKsVal, keBar, keVal, color=color.green, width=2)
        activeBullPLine := line.new(consPsBar, consPsPrice, consPeBar, consPePrice, color=priceColorBull, width=2, force_overlay=true)
        activeBullKsBar := consKsBar
        if debugAllKPivots
            if not na(consPsBar)
                label.new(consPsBar, consPsPrice - lowMarkerGap, "▼", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_none, color=color.new(#800080, 100), textcolor=color.new(#800080, 0), size=size.normal, force_overlay=true)
            if not na(consPeBar)
                label.new(consPeBar, consPePrice - lowMarkerGap, "▼", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_none, color=color.new(#800080, 100), textcolor=color.new(#800080, 0), size=size.normal, force_overlay=true)

    if keVal < lastKLowVal
        prevKLowBar := na
        prevKLowVal := na
        activeBullKLine := na
        activeBullPLine := na
        activeBullKsBar := na
    else if not lbOk
        prevKLowBar := lastKLowBar
        prevKLowVal := lastKLowVal
    lastKLowBar := keBar
    lastKLowVal := keVal

