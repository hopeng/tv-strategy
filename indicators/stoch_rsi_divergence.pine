//@version=6
// -----------------------------------------------------------------------------
// Stochastic RSI Divergence v2 (visual indicator, not automated entries)
//
// Bear div:
// 1. Save a swing high as ps. On the next swing high: if higher, treat as pe;
//    if lower, replace ps.
// 2. Window: Stoch RSI from ps to pe, widened by 5 bars on each end.
// 3. ks = %K anchor closest to ps: %K swing high (priority) or K cross-down
//    through D (fallback).
// 4. ke = %K anchor closest to pe (same rules, ke != ks).
// 5. If %K at ke <= %K at ks -> bear div confirmed, draw lines.
// 6. If %K at ke > %K at ks -> no div, clear ps/pe, start fresh.
// 7. Lookbacks: lbL = 5, lbR = 3 for both price and %K pivots.
//
// Bull div: symmetric (lower lows on price, higher lows on %K).
// -----------------------------------------------------------------------------
indicator(title="Stoch RSI Divergence v2", shorttitle="StochDiv v2", overlay=false, max_lines_count=500, max_bars_back=5000)

// --- Stoch RSI Inputs ---
smoothK     = input.int(3, "K Smoothing", minval=1)
smoothD     = input.int(3, "D Smoothing", minval=1)
lengthRSI   = input.int(14, "RSI Length", minval=1)
lengthStoch = input.int(14, "Stochastic Length", minval=1)
src         = input(close, title="RSI Source")

// --- Divergence Inputs ---
showDiv        = input.bool(true, "Show Divergence Lines", tooltip="Toggles lines on both price and indicator")
lbR            = input.int(3, "Pivot Right Lookback")
lbL            = input.int(5, "Pivot Left Lookback")
priceColor     = input.color(color.new(#FFFF00, 0), "Bullish price line color")
priceColorBear = input.color(color.new(#FF69B4, 0), "Bearish price line color")

WIN_EXTRA = 5

// --- Calculations ---
rsi1 = ta.rsi(src, lengthRSI)
k = ta.sma(ta.stoch(rsi1, rsi1, rsi1, lengthStoch), smoothK)
d = ta.sma(k, smoothD)
max_bars_back(k, 5000)
max_bars_back(d, 5000)

// --- Plotting Stoch RSI ---
plot(k, "K", color=#2962FF, linewidth=2)
plot(d, "D", color=#FF6D00, linewidth=1)
h0 = hline(80, "Upper Band", color=#787B86, linestyle=hline.style_dashed)
hline(50, "Middle Band", color=color.new(#787B86, 50))
h1 = hline(20, "Lower Band", color=#787B86, linestyle=hline.style_dashed)
fill(h0, h1, color=color.rgb(33, 150, 243, 93), title="Background")

// --- Helpers (called every bar below — satisfies Pine consistency) ---

// Bear anchor: %K swing high closest to pricePivotBar, falling back to K cross-down-through-D.
// excludeBar (-1 = none) is skipped so ke != ks.
find_k_anchor_bear(int pricePivotBar, int winLo, int winHi, int excludeBar) =>
    if na(pricePivotBar) or winHi < winLo or winHi < 0
        [na, na]
    else
        float bestVal = na
        int bestBar = na
        int bestDist = 2147483647
        for b = winLo to winHi
            if b == excludeBar
                continue
            int off = bar_index - b
            if off < 0 or na(k[off])
                continue
            float kv = k[off]
            bool isHigh = true
            for i = 1 to lbL
                if off + i > bar_index or na(k[off + i]) or k[off + i] >= kv
                    isHigh := false
                    break
            if isHigh
                for i = 1 to lbR
                    if off - i < 0 or na(k[off - i]) or k[off - i] >= kv
                        isHigh := false
                        break
            if isHigh
                int dist = math.abs(b - pricePivotBar)
                if dist < bestDist
                    bestDist := dist
                    bestBar := b
                    bestVal := kv
        if na(bestBar)
            bestDist := 2147483647
            for b = winLo to winHi
                if b == excludeBar
                    continue
                int off = bar_index - b
                if off < 0 or off + 1 > bar_index
                    continue
                if na(k[off]) or na(d[off]) or na(k[off + 1]) or na(d[off + 1])
                    continue
                if k[off] < d[off] and k[off + 1] >= d[off + 1]
                    int dist = math.abs(b - pricePivotBar)
                    if dist < bestDist
                        bestDist := dist
                        bestBar := b
                        bestVal := k[off]
        [bestVal, bestBar]

// Bull anchor: %K swing low closest to pricePivotBar, falling back to K cross-up-through-D.
find_k_anchor_bull(int pricePivotBar, int winLo, int winHi, int excludeBar) =>
    if na(pricePivotBar) or winHi < winLo or winHi < 0
        [na, na]
    else
        float bestVal = na
        int bestBar = na
        int bestDist = 2147483647
        for b = winLo to winHi
            if b == excludeBar
                continue
            int off = bar_index - b
            if off < 0 or na(k[off])
                continue
            float kv = k[off]
            bool isLow = true
            for i = 1 to lbL
                if off + i > bar_index or na(k[off + i]) or k[off + i] <= kv
                    isLow := false
                    break
            if isLow
                for i = 1 to lbR
                    if off - i < 0 or na(k[off - i]) or k[off - i] <= kv
                        isLow := false
                        break
            if isLow
                int dist = math.abs(b - pricePivotBar)
                if dist < bestDist
                    bestDist := dist
                    bestBar := b
                    bestVal := kv
        if na(bestBar)
            bestDist := 2147483647
            for b = winLo to winHi
                if b == excludeBar
                    continue
                int off = bar_index - b
                if off < 0 or off + 1 > bar_index
                    continue
                if na(k[off]) or na(d[off]) or na(k[off + 1]) or na(d[off + 1])
                    continue
                if k[off] > d[off] and k[off + 1] <= d[off + 1]
                    int dist = math.abs(b - pricePivotBar)
                    if dist < bestDist
                        bestDist := dist
                        bestBar := b
                        bestVal := k[off]
        [bestVal, bestBar]

// --- Price Pivots ---
phH = ta.pivothigh(high, lbL, lbR)
plL = ta.pivotlow(low, lbL, lbR)

int curBarH = not na(phH) ? bar_index - lbR : na
int curBarL = not na(plL) ? bar_index - lbR : na

// --- Divergence state (ps / pe chain) ---
var int bear_ps_bar = na
var float bear_ps_price = na
var int bull_ps_bar = na
var float bull_ps_price = na

// --- Bearish anchors (computed every bar) ---
bool bearHH = showDiv and not na(phH) and not na(bear_ps_bar) and not na(curBarH) and phH > bear_ps_price
int bearWL = bearHH ? math.max(0, bear_ps_bar - WIN_EXTRA) : 0
int bearWH = bearHH ? math.min(bar_index, curBarH + WIN_EXTRA) : -1

[ksValBear, ksBarBear] = find_k_anchor_bear(bear_ps_bar, bearWL, bearWH, -1)
int bearExcl = na(ksBarBear) ? -1 : ksBarBear
[keValBear, keBarBear] = find_k_anchor_bear(curBarH, bearWL, bearWH, bearExcl)

if showDiv and not na(phH)
    int curBar = bar_index - lbR
    float curPrice = phH
    if na(bear_ps_bar)
        bear_ps_bar := curBar
        bear_ps_price := curPrice
    else if curPrice > bear_ps_price
        if not na(ksBarBear) and not na(keBarBear) and keValBear <= ksValBear
            line.new(ksBarBear, ksValBear, keBarBear, keValBear, color=color.red, width=2)
            line.new(bear_ps_bar, bear_ps_price, curBar, curPrice, color=priceColorBear, width=2, force_overlay=true)
            bear_ps_bar := curBar
            bear_ps_price := curPrice
        else
            bear_ps_bar := na
            bear_ps_price := na
    else
        bear_ps_bar := curBar
        bear_ps_price := curPrice

// --- Bullish anchors (computed every bar) ---
bool bullLL = showDiv and not na(plL) and not na(bull_ps_bar) and not na(curBarL) and plL < bull_ps_price
int bullWL = bullLL ? math.max(0, bull_ps_bar - WIN_EXTRA) : 0
int bullWH = bullLL ? math.min(bar_index, curBarL + WIN_EXTRA) : -1

[ksValBull, ksBarBull] = find_k_anchor_bull(bull_ps_bar, bullWL, bullWH, -1)
int bullExcl = na(ksBarBull) ? -1 : ksBarBull
[keValBull, keBarBull] = find_k_anchor_bull(curBarL, bullWL, bullWH, bullExcl)

if showDiv and not na(plL)
    int curBar = bar_index - lbR
    float curPrice = plL
    if na(bull_ps_bar)
        bull_ps_bar := curBar
        bull_ps_price := curPrice
    else if curPrice < bull_ps_price
        if not na(ksBarBull) and not na(keBarBull) and keValBull >= ksValBull
            line.new(ksBarBull, ksValBull, keBarBull, keValBull, color=color.green, width=2)
            line.new(bull_ps_bar, bull_ps_price, curBar, curPrice, color=priceColor, width=2, force_overlay=true)
            bull_ps_bar := curBar
            bull_ps_price := curPrice
        else
            bull_ps_bar := na
            bull_ps_price := na
    else
        bull_ps_bar := curBar
        bull_ps_price := curPrice
